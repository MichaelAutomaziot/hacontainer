# Supabase (project ref zkwkuexvftxdwsdamewx)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth (web client wired to Supabase callback)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Mirakl Seller API — Super-Pharm production tenant
MIRAKL_BASE_URL=https://superpharm-prod.mirakl.net
MIRAKL_API_KEY=

# OpenRouter (LLM gateway)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Konimbo (set after Yossi delivers; scraper does not need this)
KONIMBO_API_KEY=

# Worker queue
REDIS_URL=

# HaContainer source
HACONTAINER_BASE_URL=https://www.hacontainer.co.il
HACONTAINER_SITEMAP=https://www.hacontainer.co.il/sitemap.xml
HACONTAINER_SCRAPE_RPS=1
HACONTAINER_USER_AGENT="RanFainaHub/0.1 (+contact: michael@automaziot.ai)"

# App
APP_BASE_URL=http://localhost:3000
NODE_ENV=development
